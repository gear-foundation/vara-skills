{
  "name": "sails-indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf lib",
    "codegen": "squid-typeorm-codegen",
    "db:generate": "squid-typeorm-migration generate",
    "db:apply": "squid-typeorm-migration apply",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "dev:processor": "tsx src/main.ts",
    "dev:api": "tsx src/api.ts",
    "start:processor": "node lib/main.js",
    "start:api": "node lib/api.js"
  },
  "dependencies": {
    "@polkadot/api": "16.5.4",
    "@polkadot/types": "16.5.4",
    "@polkadot/util": "14.0.3",
    "@polkadot/util-crypto": "14.0.1",
    "@subsquid/substrate-processor": "8.6.1",
    "@subsquid/typeorm-config": "4.1.1",
    "@subsquid/typeorm-store": "latest",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "8.20.0",
    "postgraphile": "4.14.1",
    "postgraphile-plugin-connection-filter": "2.3.0",
    "reflect-metadata": "^0.2.2",
    "sails-js": "0.5.1",
    "sails-js-parser": "0.5.1",
    "typeorm": "^0.3.21"
  },
  "devDependencies": {
    "@subsquid/typeorm-codegen": "2.0.2",
    "@subsquid/typeorm-migration": "1.3.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/pg": "8.20.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
