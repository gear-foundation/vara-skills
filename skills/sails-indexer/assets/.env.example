# Subsquid archive gateway used for historical ingestion.
VARA_ARCHIVE_URL=https://v2.archive.subsquid.io/network/vara-testnet

# Vara archive RPC endpoint used by the Subsquid processor for historical chain queries.
# Do not use a live non-archive public RPC endpoint here.
VARA_RPC_URL=

VARA_FROM_BLOCK=
VARA_PROGRAM_ID=
VARA_IDL_PATH=./idl/app.idl
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sails_indexer
INDEXER_PORT=4350
INDEXER_CORS_ORIGIN=http://localhost:3000
