type BasketMarketInit = struct {
  admin_role: actor_id,
  settler_role: actor_id,
  liveness_ms: u64,
};

type BasketItem = struct {
  poly_market_id: str,
  poly_slug: str,
  weight_bps: u16,
  selected_outcome: Outcome,
};

type Outcome = enum {
  YES,
  NO,
};

type BasketAssetKind = enum {
  Vara,
  Bet,
};

type ItemResolution = struct {
  item_index: u8,
  resolved: Outcome,
  poly_slug: str,
  poly_condition_id: opt str,
  poly_price_yes: u16,
  poly_price_no: u16,
};

type BasketMarketConfig = struct {
  admin_role: actor_id,
  settler_role: actor_id,
  liveness_ms: u64,
  vara_enabled: bool,
};

type Basket = struct {
  id: u64,
  creator: actor_id,
  name: str,
  description: str,
  items: vec BasketItem,
  created_at: u64,
  status: BasketStatus,
  asset_kind: BasketAssetKind,
};

type BasketStatus = enum {
  Active,
  SettlementPending,
  Settled,
};

type BasketMarketError = enum {
  Unauthorized,
  BasketNotFound,
  BasketNotActive,
  BasketAssetMismatch,
  NoItems,
  InvalidWeights,
  DuplicateBasketItem,
  TooManyItems,
  NameTooLong,
  DescriptionTooLong,
  MarketIdTooLong,
  SlugTooLong,
  PayloadTooLong,
  VaraDisabled,
  SettlementAlreadyExists,
  SettlementNotFound,
  SettlementNotProposed,
  SettlementNotFinalized,
  ChallengeDeadlineNotPassed,
  InvalidIndexAtCreation,
  InvalidBetAmount,
  InvalidResolutionCount,
  DuplicateResolutionIndex,
  ResolutionIndexOutOfBounds,
  ResolutionSlugMismatch,
  InvalidResolution,
  AlreadyClaimed,
  NothingToClaim,
  TransferFailed,
  MathOverflow,
  EventEmitFailed,
  InvalidConfig,
};

type Position = struct {
  basket_id: u64,
  user: actor_id,
  shares: u128,
  claimed: bool,
  index_at_creation_bps: u16,
};

type Settlement = struct {
  basket_id: u64,
  proposer: actor_id,
  item_resolutions: vec ItemResolution,
  payout_per_share: u128,
  payload: str,
  proposed_at: u64,
  challenge_deadline: u64,
  finalized_at: opt u64,
  status: SettlementStatus,
};

type SettlementStatus = enum {
  Proposed,
  Finalized,
};

constructor {
  New : (init: BasketMarketInit);
};

service BasketMarket {
  BetOnBasket : (basket_id: u64, index_at_creation_bps: u16) -> u128;
  Claim : (basket_id: u64) -> u128;
  CreateBasket : (name: str, description: str, items: vec BasketItem, asset_kind: BasketAssetKind) -> u64;
  FinalizeSettlement : (basket_id: u64) -> null;
  ProposeSettlement : (basket_id: u64, item_resolutions: vec ItemResolution, payload: str) -> null;
  SetConfig : (config: BasketMarketConfig) -> null;
  SetVaraEnabled : (enabled: bool) -> null;
  query GetBasket : (basket_id: u64) -> result (Basket, BasketMarketError);
  query GetBasketCount : () -> u64;
  query GetConfig : () -> BasketMarketConfig;
  query GetPositions : (user: actor_id) -> vec Position;
  query GetSettlement : (basket_id: u64) -> result (Settlement, BasketMarketError);
  query IsVaraEnabled : () -> bool;

  events {
    BasketCreated: struct {
      basket_id: u64,
      creator: actor_id,
      asset_kind: BasketAssetKind,
    };
    VaraBetPlaced: struct {
      basket_id: u64,
      user: actor_id,
      amount: u128,
      user_total: u128,
      index_at_creation_bps: u16,
    };
    SettlementProposed: struct {
      basket_id: u64,
      proposer: actor_id,
      payout_per_share: u128,
      challenge_deadline: u64,
    };
    SettlementFinalized: struct {
      basket_id: u64,
      finalized_at: u64,
      payout_per_share: u128,
    };
    Claimed: struct {
      basket_id: u64,
      user: actor_id,
      amount: u128,
    };
    VaraSupportUpdated: struct {
      enabled: bool
    };
    ConfigUpdated: struct {
      config: BasketMarketConfig
    };
  }
};

